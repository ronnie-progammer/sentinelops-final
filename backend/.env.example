# ─── CORS ────────────────────────────────────────────────────────────────────
# Comma-separated allowed origins. Add your Vercel URL in production.
CORS_ORIGINS=http://localhost:5173,http://localhost:3000

# ─── Database ────────────────────────────────────────────────────────────────
# SQLite is the default (no env var needed). To swap to PostgreSQL, set this:
# DATABASE_URL=postgresql://user:password@host:5432/sentinelops

# ─── ML ──────────────────────────────────────────────────────────────────────
# Pickles are written to backend/ml/artifacts/ on first startup.
# Nothing to configure unless you change the path.
