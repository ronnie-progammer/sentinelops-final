# ─── CORS ────────────────────────────────────────────────────────────────────
# Comma-separated allowed origins. Add your Vercel URL in production.
CORS_ORIGINS=http://localhost:5173,http://localhost:3000

# ─── Database ────────────────────────────────────────────────────────────────
# SQLite is the default (no env var needed). To swap to PostgreSQL, set this:
# DATABASE_URL=postgresql://user:password@host:5432/sentinelops

# ─── ML ──────────────────────────────────────────────────────────────────────
# Pickles are written to backend/ml/artifacts/ on first startup.
# Nothing to configure unless you change the path.

# AI Alert Summarizer
SUMMARIZER_PROVIDER=rule  # Options: rule | anthropic | openai (future)

# Slack Notifications
SLACK_ENABLED=false
SLACK_WEBHOOK_URL=

# PagerDuty Notifications
PAGERDUTY_ENABLED=false
PAGERDUTY_INTEGRATION_KEY=
PAGERDUTY_SEVERITY_THRESHOLD=HIGH

# ─── CrowdStrike Integration ─────────────────────────────────────────────────
CROWDSTRIKE_CLIENT_ID=
CROWDSTRIKE_CLIENT_SECRET=
CROWDSTRIKE_BASE_URL=https://api.crowdstrike.com

# ─── Datadog Integration ─────────────────────────────────────────────────────
DATADOG_API_KEY=
DATADOG_APP_KEY=
DATADOG_SITE=datadoghq.com

# ─── Splunk Integration ──────────────────────────────────────────────────────
SPLUNK_HOST=
SPLUNK_TOKEN=
SPLUNK_PORT=8089

# ─── Integration Scheduler ───────────────────────────────────────────────────
INTEGRATION_POLL_INTERVAL_MINUTES=5

# ─── Compliance Reports ───────────────────────────────────────────────────────
COMPLIANCE_REPORTS_DIR=reports/  # relative to backend/
